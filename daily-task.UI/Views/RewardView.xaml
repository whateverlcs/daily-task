<UserControl x:Class="daily_task.UI.Views.RewardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helper="clr-namespace:daily_task.UI.Helpers"
             xmlns:local="clr-namespace:daily_task.UI.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cal="http://www.caliburnproject.org"
             Background="#F8FAFC"
             FontFamily="{DynamicResource RobotoFont}"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="700">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter" />
        <helper:InvertedBooleanToVisibilityConverterHelper x:Key="InvertedVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="80"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1">
            <Button Background="Transparent" BorderThickness="0" Padding="0"
        cal:Message.Attach="GoToHome()"
        VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" Height="100" ToolTip="Click to access the home">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Home" Foreground="#0F172A" Width="50" Height="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="Home" Foreground="#0F172A" FontWeight="Medium" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Background="Transparent" BorderThickness="0" Padding="0"
        VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" Height="100" ToolTip="Click to access the rewards">
                <StackPanel>
                    <materialDesign:PackIcon Kind="License" Foreground="#0D9488" Width="50" Height="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="Rewards" Foreground="#0D9488" FontWeight="Medium" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Background="Transparent" BorderThickness="0" Padding="0"
        cal:Message.Attach="GoToProfile()"
        VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" Height="100" ToolTip="Click to access the profile">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Account" Foreground="#0F172A" Width="50" Height="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="Profile" Foreground="#0F172A" FontWeight="Medium" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Vertical" ToolTip="Gold Balance" HorizontalAlignment="Right" VerticalAlignment="Center">
            <materialDesign:PackIcon Kind="Gold" Foreground="#D97706" VerticalAlignment="Center" HorizontalAlignment="Center" Width="50" Height="50"/>
            <TextBlock Text="{Binding TotalGold}" Foreground="#D97706" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Medium" FontSize="18" />
        </StackPanel>

        <StackPanel x:Name="EmptyStatePanel" Grid.Row="3" Grid.RowSpan="3" Grid.Column="1" Visibility="{Binding ShowMessageWithNoRewards, Converter={StaticResource VisibilityConverter}}"
HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="/Resources/Images/reward-not-found.png" Width="700" Height="500"/>
            <TextBlock Text="Create new rewards to claim!"
        Foreground="#353535" FontSize="30"
        HorizontalAlignment="Center" Margin="10" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="600"/>
        </StackPanel>

        <TextBlock Grid.Column="1" Grid.Row="3" Text="Rewards" Foreground="#0F172A" FontSize="32" FontWeight="Medium" HorizontalAlignment="Center" Margin="10" TextAlignment="Center" MaxWidth="600" Visibility="{Binding Rewards.Count, Converter={StaticResource InvertedVisibilityConverter}}"/>

        <ScrollViewer Grid.Row="5" Grid.Column="1" VerticalScrollBarVisibility="Auto" MaxHeight="600">
            <ItemsControl x:Name="Rewards"
          Visibility="{Binding Rewards.Count, Converter={StaticResource InvertedVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="10" Margin="0,0,10,15" Padding="20" Width="1070">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50" />
                                    <RowDefinition Height="60" />
                                </Grid.RowDefinitions>

                                <Button Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Background="Transparent" BorderThickness="0" Padding="0"
                                    cal:Message.Attach="EditReward($this.DataContext.Id)" VerticalAlignment="Center" HorizontalAlignment="Right" Width="50" Height="30" ToolTip="Click to edit the current reward">
                                    <materialDesign:PackIcon Kind="PencilBoxOutline" Foreground="#64748B" Width="23" Height="23"/>
                                </Button>

                                <Button Grid.Row="1" Grid.RowSpan="2" Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="0"
                                    cal:Message.Attach="ClaimReward($this.DataContext.Id)"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Width="50" Height="50" ToolTip="Click to claim the reward">
                                    <StackPanel>
                                        <materialDesign:PackIcon Kind="CartVariant" Foreground="#D97706" Width="30" Height="30"/>
                                        <TextBlock Text="{Binding Gold}" Foreground="#D97706" FontWeight="Medium" FontSize="12" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Text="{Binding Name}" Foreground="#0F172A" FontSize="18" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Column="2" Grid.Row="5" cal:Message.Attach="AddReward()" VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="65" Height="65"
        Background="Transparent" BorderThickness="0" Padding="0" ToolTip="Click to add a new reward">
            <materialDesign:PackIcon Kind="PlusBoxOutline"
                         Foreground="#059669"
                         Width="65" Height="65"/>
        </Button>
        <Grid Grid.Column="0" Grid.ColumnSpan="9" Grid.Row="0" Grid.RowSpan="10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Visibility="{Binding Loading, Converter={StaticResource VisibilityConverter}}" Background="{StaticResource MahApps.Brushes.Gray.SemiTransparent}">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1000" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="180"></RowDefinition>
                    <RowDefinition Height="170"></RowDefinition>
                    <RowDefinition Height="180"></RowDefinition>
                </Grid.RowDefinitions>
                <materialDesign:Card Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Width="200" Height="190" Padding="8" Background="GhostWhite" Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}" UniformCornerRadius="2" />
                <TextBlock Grid.Column="0" Grid.Row="1" Text="LOADING" HorizontalAlignment="Center" />
                <ProgressBar Grid.Column="0" Grid.Row="1" Width="100" Height="60" Style="{DynamicResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Value="33"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
