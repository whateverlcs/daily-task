<UserControl x:Class="daily_task.UI.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:daily_task.UI.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cal="http://www.caliburnproject.org"
             Background="#F8FAFC"
             FontFamily="{DynamicResource RobotoFont}"
             mc:Ignorable="d"
             d:DesignHeight="620" d:DesignWidth="950">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="50" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1">
            <Button Background="Transparent" BorderThickness="0" Padding="0"
cal:Message.Attach="GoToHome()"
VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" Height="100" ToolTip="Click to access the home">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Home" Foreground="#0F172A" Width="50" Height="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="Home" Foreground="#0F172A" FontWeight="Medium" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Background="Transparent" BorderThickness="0" Padding="0"
cal:Message.Attach="GoToRewards()"
VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" Height="100" ToolTip="Click to access the rewards">
                <StackPanel>
                    <materialDesign:PackIcon Kind="License" Foreground="#0F172A" Width="50" Height="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="Rewards" Foreground="#0F172A" FontWeight="Medium" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Background="Transparent" BorderThickness="0" Padding="0"
VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" Height="100" ToolTip="Click to access the profile">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Account" Foreground="#0D9488" Width="50" Height="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="Profile" Foreground="#0D9488" FontWeight="Medium" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="1" Text="Perfil"
               FontSize="32" FontWeight="Bold" Foreground="#0F172A"
               HorizontalAlignment="Center" Margin="0,40"/>

        <Border Grid.Row="4" Grid.Column="1" Background="White" CornerRadius="15"
            BorderBrush="#E2E8F0" BorderThickness="1"
            Width="850" Height="180" HorizontalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="40,0">
                    <TextBlock Text="W   E   L   C   O   M   E      B   A   C   K   ,"
                           FontSize="12" Foreground="#64748B" FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding User}"
                            FontSize="32" FontWeight="Bold" Foreground="#0F172A"/>
                        <Button Background="Transparent" BorderThickness="0" Padding="0"
                            cal:Message.Attach="EditUsername()" VerticalAlignment="Center" Width="50" Height="30" ToolTip="Click to edit the current username">
                            <materialDesign:PackIcon Kind="PencilBoxOutline" Foreground="#64748B" Width="23" Height="23"/>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{Binding Rank}"
                           FontSize="16" Foreground="#0D9488" FontWeight="Regular"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,40,0">
                    <TextBlock Text="G   O   L   D      B   A   L   A   N   C   E"
                           FontSize="12" Foreground="#64748B" HorizontalAlignment="Right" FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Gold" Foreground="#D97706"
                                             Width="45" Height="45" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalGold}"
                               FontSize="42" FontWeight="Black" Foreground="#D97706"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Canvas Grid.Column="1" Grid.Row="5" Height="40" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Path Stroke="#E2E8F0" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="425,0">
                            <LineSegment Point="425,20" />
                        </PathFigure>

                        <PathFigure StartPoint="141,20">
                            <LineSegment Point="708,20" />
                        </PathFigure>

                        <PathFigure StartPoint="141,20">
                            <LineSegment Point="141,40" />
                        </PathFigure>

                        <PathFigure StartPoint="425,20">
                            <LineSegment Point="425,40" />
                        </PathFigure>

                        <PathFigure StartPoint="708,20">
                            <LineSegment Point="708,40" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Canvas>

        <Grid Grid.Row="6" Grid.Column="1" Width="850" HorizontalAlignment="Center" Margin="0,30,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Height="140">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="TASKS COMPLETED" FontSize="11" Foreground="#000000" HorizontalAlignment="Center" FontWeight="Medium"/>
                    <TextBlock Text="{Binding TasksCompleted}" FontSize="32" Foreground="#0D9488" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Height="140">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="GOLD EARNED" FontSize="11" Foreground="#000000" HorizontalAlignment="Center" FontWeight="Medium"/>
                    <TextBlock Text="{Binding GoldEarned}" FontSize="32" Foreground="#D97706" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Height="140">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CLAIMED REWARDS" FontSize="11" Foreground="#000000" HorizontalAlignment="Center" FontWeight="Medium"/>
                    <TextBlock Text="{Binding ClaimedRewards}" FontSize="32" Foreground="#0F172A" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Column="0" Grid.ColumnSpan="9" Grid.Row="0" Grid.RowSpan="10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Visibility="{Binding Loading, Converter={StaticResource VisibilityConverter}}" Background="{StaticResource MahApps.Brushes.Gray.SemiTransparent}">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1000" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="180"></RowDefinition>
                    <RowDefinition Height="170"></RowDefinition>
                    <RowDefinition Height="180"></RowDefinition>
                </Grid.RowDefinitions>
                <materialDesign:Card Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Width="200" Height="190" Padding="8" Background="GhostWhite" Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}" UniformCornerRadius="2" />
                <TextBlock Grid.Column="0" Grid.Row="1" Text="LOADING" HorizontalAlignment="Center" />
                <ProgressBar Grid.Column="0" Grid.Row="1" Width="100" Height="60" Style="{DynamicResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Value="33"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
