<UserControl x:Class="daily_task.UI.Views.CreateTaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:daily_task.UI.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cal="http://www.caliburnproject.org"
             Background="#F8FAFC"
             FontFamily="{DynamicResource RobotoFont}"
             mc:Ignorable="d"
             d:DesignHeight="430" d:DesignWidth="840">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="170"></RowDefinition>
            <RowDefinition Height="20"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="1" Text="New Task" Foreground="#0F172A" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="10" TextAlignment="Center" MaxWidth="600"/>
        <TextBox x:Name="Title" Style="{StaticResource MaterialDesignOutlinedTextBox}" Grid.Column="1" Grid.Row="3" VerticalAlignment="Top" Width="400" FontSize="15" Height="60" Background="White" BorderBrush="#64748B" materialDesign:ButtonAssist.CornerRadius="10" materialDesign:HintAssist.Hint="Title" IsEnabled="{Binding EnableFields, Mode=TwoWay}" />
        <ComboBox x:Name="Priority" Style="{StaticResource MaterialDesignOutlinedComboBox}" ItemsSource="{Binding ListPriority}" DisplayMemberPath="Priority" SelectedItem="{Binding SelectedPriority, Mode=TwoWay}" Grid.Column="3" Grid.Row="3" VerticalAlignment="Top" HorizontalAlignment="Stretch" FontSize="15" Width="400" Height="60" Background="White" BorderBrush="#64748B" materialDesign:HintAssist.Hint="Priority" IsEnabled="{Binding EnableFields, Mode=TwoWay}" />
        <TextBox x:Name="Description" Style="{StaticResource MaterialDesignOutlinedTextBox}" TextWrapping="Wrap" AcceptsReturn="True" Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Width="810" Height="170" FontSize="15" Background="White" BorderBrush="#64748B" materialDesign:ButtonAssist.CornerRadius="10" materialDesign:HintAssist.Hint="Description" IsEnabled="{Binding EnableFields, Mode=TwoWay}" />
        <Button Grid.Column="1" Grid.Row="7" Width="190" Height="30" x:Name="ReturnToHome" Foreground="#0D9488" Background="{x:Null}" BorderBrush="{x:Null}" HorizontalAlignment="Left" VerticalAlignment="Center" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" Padding="-4" IsEnabled="{Binding EnableFields, Mode=TwoWay}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Grid.Column="0" Width="24" Height="24" Kind="ArrowLeft" />
                <TextBlock Grid.Column="1" Text="Return to home" FontSize="18" Margin="5 0 0 0" />
            </StackPanel>
        </Button>
        <Button x:Name="CreateTask" Style="{StaticResource MaterialDesignFlatDarkBgButton}" Grid.Column="3" Grid.Row="7" VerticalAlignment="Top" Height="60" Background="#0D9488" Foreground="#FFFFFF" IsEnabled="{Binding EnableFields, Mode=TwoWay}" materialDesign:ButtonAssist.CornerRadius="10" >
            <StackPanel Orientation="Horizontal">
                <ProgressBar Width="20" Height="20" Style="{DynamicResource MaterialDesignCircularProgressBar}" Foreground="#FFFFFF" IsIndeterminate="True" Value="33" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding Loading, Converter={StaticResource VisibilityConverter}}"/>
                <TextBlock Text="Create Task" FontSize="18" Margin="5 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
